# Generate a real secret with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-string

# Path to the SQLite file. On Railway, mount a volume and point this at it
# so data survives redeploys, e.g. /data/app.db
DATABASE_PATH=./app.db

# Your deployed Vercel frontend URL, for CORS. e.g. https://emotion-journal.vercel.app
FRONTEND_URL=http://localhost:5173
